# Frontend Environment Variables
# Copy this file to .env.local for development
# For Vercel deployment, set these in Vercel Dashboard > Settings > Environment Variables

# =================== API ===================
# Your Render backend URL (e.g., https://your-app.onrender.com)
NEXT_PUBLIC_API_URL=https://your-backend-api.onrender.com

# =================== PRINT AGENT (Optional - for local printing) ===================
NEXT_PUBLIC_PRINT_AGENT_URL=http://127.0.0.1:9100

# =================== ENVIRONMENT ===================
NODE_ENV=production
